# ============================================================
# OCTO-CRM — Environment Variables Example
# Copy this file to .env and fill in the values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_GATEWAY_URL=http://localhost:4000

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://octocrm:secret@localhost:5432/octocrm
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=octocrm
DATABASE_USER=octocrm
DATABASE_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Authentication ─────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=change_me_in_production
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=secret
SMTP_FROM=no-reply@example.com

# ── File Storage (S3-compatible) ───────────────────────────────
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=octo-crm-files
S3_ACCESS_KEY=access_key
S3_SECRET_KEY=secret_key
S3_REGION=us-east-1

# ── Search (Meilisearch) ───────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# ── Queue (BullMQ) ────────────────────────────────────────────
QUEUE_REDIS_URL=redis://localhost:6379

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ── Services ──────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
CRM_SERVICE_URL=http://localhost:4003
BILLING_SERVICE_URL=http://localhost:4004
NOTIFICATION_SERVICE_URL=http://localhost:4005
ANALYTICS_SERVICE_URL=http://localhost:4006
FILE_SERVICE_URL=http://localhost:4007
AUDIT_SERVICE_URL=http://localhost:4008
