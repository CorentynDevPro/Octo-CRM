{
  "name": "octo-crm",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade open source CRM — TurboRepo monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,sql}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:migrate": "turbo run db:migrate --filter=@octo-crm/database",
    "db:seed": "turbo run db:seed --filter=@octo-crm/database",
    "db:reset": "turbo run db:reset --filter=@octo-crm/database",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
